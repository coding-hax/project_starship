# Copy to .env.local for development. Never commit a real .env.
# Local Postgres comes from docker-compose.yml.
DATABASE_URL=postgresql://starship:starship@localhost:5432/starship

# Single-user authorisation. Every API route checks the session against this id.
# Generate once with:  node -e "console.log(crypto.randomUUID())"
OWNER_USER_ID=00000000-0000-0000-0000-000000000000

# WebAuthn relying party. RP_ID is the bare hostname (no scheme, no port).
RP_ID=localhost
RP_NAME=Starship
RP_ORIGIN=http://localhost:3000
